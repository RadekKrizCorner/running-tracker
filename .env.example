# App
APP_ENV=development
APP_NAME=Running Tracker
APP_BASE_URL=http://localhost:8009
FRONTEND_BASE_URL=http://localhost:5173
API_PORT=8009
FRONTEND_PORT=5173
SECRET_KEY=replace-me-with-a-long-random-secret
TOKEN_ENCRYPTION_KEY=replace-with-fernet-key
OWNER_EMAIL=you@example.com

# Database
DATABASE_URL=postgresql+psycopg://running:running@db:5432/running_tracker

# Redis / RQ
REDIS_URL=redis://redis:6379/0
STRAVA_AUTO_SYNC_ENABLED=true
STRAVA_AUTO_SYNC_INTERVAL_SECONDS=21600

# Strava
STRAVA_CLIENT_ID=replace-me
STRAVA_CLIENT_SECRET=replace-me
STRAVA_REDIRECT_URI=http://localhost:8009/api/v1/connections/strava/callback
STRAVA_SCOPES=read,activity:read_all

# Frontend
VITE_API_BASE_URL=http://localhost:8009/api/v1
VITE_BASE_PATH=/
