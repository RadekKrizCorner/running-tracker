# App
APP_ENV=development
APP_NAME=Running Tracker
APP_BASE_URL=http://localhost:8009
FRONTEND_BASE_URL=http://localhost:5173
API_PORT=8009
FRONTEND_PORT=5173
SECRET_KEY=replace-me-with-a-long-random-secret
TOKEN_ENCRYPTION_KEY=replace-with-fernet-key
OWNER_EMAIL=you@example.com

# Database
DATABASE_URL=postgresql+psycopg://running:running@db:5432/running_tracker

# Redis / RQ
REDIS_URL=redis://redis:6379/0
STRAVA_AUTO_SYNC_ENABLED=true
STRAVA_AUTO_SYNC_INTERVAL_SECONDS=21600

# Portfolio demo account
DEMO_ACCOUNT_ENABLED=false
DEMO_ACCOUNT_EMAIL=demo@example.com
DEMO_ACCOUNT_PASSWORD=
DEMO_ACCOUNT_DISPLAY_NAME=Portfolio Demo
DEMO_REFRESH_ENABLED=false
DEMO_REFRESH_INTERVAL_SECONDS=86400
DEMO_REFRESH_FROM_OWNER_PATTERNS=true
DEMO_REFRESH_HISTORY_WEEKS=78

# Strava
STRAVA_CLIENT_ID=replace-me
STRAVA_CLIENT_SECRET=replace-me
STRAVA_REDIRECT_URI=http://localhost:8009/api/v1/connections/strava/callback
STRAVA_SCOPES=read,activity:read_all

# Optional self-hosted routing
ROUTING_ENABLED=false
ROUTING_PROVIDER=valhalla
VALHALLA_BASE_URL=
ROUTE_SUGGESTION_MAX_DISTANCE_M=50000
ROUTE_SUGGESTION_MIN_LAT=48.5
ROUTE_SUGGESTION_MAX_LAT=51.1
ROUTE_SUGGESTION_MIN_LNG=12.0
ROUTE_SUGGESTION_MAX_LNG=18.9

# Frontend
VITE_API_BASE_URL=http://localhost:8009/api/v1
VITE_BASE_PATH=/
