APP_ENV=development
APP_NAME=Running Tracker
APP_BASE_URL=http://localhost:8009
FRONTEND_BASE_URL=http://localhost:8080
REDIS_URL=redis://redis:6379/0
STRAVA_REDIRECT_URI=http://localhost:8009/api/v1/connections/strava/callback
STRAVA_SCOPES=read,activity:read_all
STRAVA_AUTO_SYNC_ENABLED=true
STRAVA_AUTO_SYNC_INTERVAL_SECONDS=21600
